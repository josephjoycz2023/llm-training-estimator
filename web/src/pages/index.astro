          checkboxEnabled: "enabled",
          fieldMetaRequired: "required",
        },
        zh: {
          appTitle: "LLM 训练估算器",
          appDescription:
            "按统一 schema 分块填写参数，进行类型校验，并估算显存、训练时长、GPU-hours 与租赁成本。",
          languageToggle: "语言：中文",
          loadExample: "加载 Dense 示例",
          clearForm: "清空",
          estimateButton: "开始估算",
          progressTitle: "进度",
          resultTitle: "结果",
          comparisonTitle: "硬件对比",
          comparisonHelper: "在 hardware 模块中多选 GPU 预设，可比较不同设备的训练时长与成本。",
          summaryTitle: "总结分析",
          rawResultTitle: "原始结果",
          progressLabels: ["校验", "估算", "对比", "总结", "展示"],
          progressStates: {
            idle: "空闲",
            waiting: "等待中",
            running: "进行中",
            queued: "已排队",
            done: "已完成",
            skipped: "已跳过",
            unavailable: "不可用",
            complete: "完成",
            error: "出错",
          },
          progressStages: {
            idle: "空闲",
            validating: "正在校验配置",
            estimating: "正在运行估算 pipeline",
            estimateReady: "估算结果已就绪",
            comparing: "正在比较硬件预设",
            summarizing: "正在生成总结分析",
            finalizing: "正在整理结果",
            complete: "完成",
            warning: "已完成，但有警告",
          },
          eta: {
            unknown: "预计时间：暂无",
            left: (seconds) => `预计剩余时间：${seconds} 秒`,
            compare: "预计剩余时间：2-4 秒",
            summary: "预计剩余时间：10-20 秒",
            ready: "预计剩余时间：0 秒",
          },
          metrics: {
            runnable: "是否可运行",
            risk: "风险等级",
            memory: "平均每卡显存",
            utilization: "显存利用率",
            time: "训练时长",
            gpuHours: "GPU-hours",
            cost: "成本",
            provider: "总结模型来源",
          },
          values: {
            notRun: "未运行",
            pending: "等待中",
            noSummaryRequested: "未请求总结分析。",
            yes: "是",
            no: "否",
            current: "当前",
            none: "无",
            auto: "自动",
            noComparison: "尚未请求硬件对比。",
            comparisonLoading: "正在比较所选硬件预设...",
            loadingOptions: "正在加载硬件预设...",
            unavailable: "不可用",
          },
          memoryNote: {
            generic: "显存以平均每张 GPU 的数值展示，并与单卡显存上限进行比较。",
            withCount: (gpuCount) =>
              `显存以 ${gpuCount} 张 GPU 的平均单卡数值展示，并与单卡显存上限进行比较。`,
          },
          status: {
            loadingHardware: "正在加载硬件预设...",
            validating: "正在校验输入...",
            estimateReady: "估算结果已返回，正在立即展示...",
            waitingBackground: "估算结果已可见，硬件对比与总结分析仍在后台处理中...",
            estimateComplete: "估算完成。",
            compareComplete: "硬件对比完成。",
            summaryComplete: "估算与总结分析已完成。",
            allComplete: "估算、硬件对比与总结分析均已完成。",
            summaryWarning: "估算结果可用，但部分后台分析失败或暂不可用。",
          },
          errors: {
            required: "该字段为估算必填项。",
            integer: "必须为整数。",
            number: "必须为数字。",
            fixFields: "请先修正高亮字段。",
            min: (value) => `必须大于或等于 ${value}。`,
            max: (value) => `必须小于或等于 ${value}。`,
          },
          summary: {
            placeholder: "运行一次估算后，这里会生成 Markdown 总结分析。",
            waiting: "正在等待总结分析...",
            unavailableTitle: "总结分析暂不可用。",
          },
          comparison: {
            placeholder: "尚未请求硬件对比。",
            waiting: "正在比较所选硬件预设...",
            unavailableTitle: "硬件对比失败。",
            presetMeaning:
              "选择主硬件预设用于主结果估算。它会自动填充 hardware、并行 GPU 数量和 price profile 相关字段。",
            presetLabel: "hardware.gpu_type",
            presetType: "预设选择器",
            presetEmpty: "手动 / 自定义",
            compareMeaning:
              "选择一个或多个 GPU 预设，横向比较训练时长与成本。当前硬件 profile 会自动加入比较。",
            compareLabel: "hardware.gpu_type[]",
            compareType: "多选对比",
            loading: "正在加载硬件预设...",
            noOptions: "没有可用的硬件预设。",
            currentBadge: "当前",
            insightFastest: (label, hours) => `最快：${label}，训练时长 ${hours}。`,
            insightCheapest: (label, cost) => `最便宜：${label}，成本 ${cost}。`,
            insightOnlyOne: "至少选择两个预设，横向对比会更有意义。",
            columns: {
              profile: "Profile",
              gpu: "GPU",
              count: "GPU 数",
              memory: "平均每卡显存",
              time: "训练时长",
              cost: "成本",
              deltaTime: "时长差值",
              deltaCost: "成本差值",
              runnable: "可运行",
              risk: "风险",
              notes: "说明",
            },
          },
          hardwarePresetWarning:
            "所选预设的 GPU 数量与当前 tensor / pipeline 并行布局不兼容，因此没有自动改写 data parallel size。",
          checkboxEnabled: "启用",
          fieldMetaRequired: "必填",
        },
      };

      const schema = [
        {
          id: "run",
          title: "run",
          description: { en: "Metadata", zh: "元数据" },
          fields: [
            field("version", "string", "Config schema version marker. Currently informational.", "配置 schema 版本标记，当前主要用于说明。", { default: "0.1" }),
            field("run.name", "string", "Run identifier used in reports and output JSON.", "运行名称，会出现在报告和输出 JSON 中。", { required: true }),
            field("run.description", "string", "Human-readable note for this run.", "本次估算的人类可读说明。", { multiline: true }),
          ],
        },
        {
          id: "model",
          title: "model",
          description: { en: "Architecture and scale", zh: "模型结构与规模" },
          fields: [
            field("model.name", "string", "Model name passed through to backend configs.", "模型名称，会传递给后端配置。", { required: true }),
            field("model.architecture", "enum", "Select dense or mixture-of-experts validation behavior.", "选择 dense 或 MoE，并触发对应的校验规则。", { options: ["dense", "moe"], default: "dense" }),
            field("model.total_params_b", "float", "Total model parameters in billions. Used by memory estimation.", "模型总参数量，单位为十亿。显存估算会使用。", { required: true }),
            field("model.active_params_b", "float", "Active parameters in billions. Dense defaults to total_params_b; MoE requires it.", "激活参数量，单位为十亿。dense 可留空，MoE 必填。", { nullable: true }),
            field("model.num_layers", "int", "Transformer layer count.", "Transformer 层数。", { required: true }),
            field("model.hidden_size", "int", "Hidden dimension.", "隐藏层维度。", { required: true }),
            field("model.num_attention_heads", "int", "Attention head count.", "注意力头数。", { required: true }),
            field("model.vocab_size", "int", "Vocabulary size.", "词表大小。", { required: true }),
            field("model.seq_len", "int", "Training sequence length.", "训练序列长度。", { required: true }),
            field("model.moe.num_experts", "int", "Total number of experts. Required for MoE; leave empty for dense.", "专家总数。MoE 必填，dense 留空。", { nullable: true }),
            field("model.moe.experts_per_token", "int", "Top-k experts activated per token. Required for MoE; leave empty for dense.", "每个 token 激活的专家数。MoE 必填，dense 留空。", { nullable: true }),
            field("model.moe.expert_parallel_size", "int", "Model-local expert parallel size. Must stay 1 for dense.", "模型局部专家并行大小。dense 必须为 1。", { default: 1 }),
          ],
        },
        {
          id: "training",
          title: "training",
          description: { en: "Mode, precision, batch, tokens", zh: "训练方式、精度、batch 与 token" },
          fields: [
            field("training.mode", "enum", "Training method. Only full has precise backend estimates in this MVP.", "训练方式。当前 MVP 只有 full 会给出较完整的后端估算。", { options: ["full", "lora", "qlora"], default: "full" }),
            field("training.precision", "enum", "Training precision. Low-bit training support depends on the backend.", "训练精度。低比特训练的后端支持可能不同。", { options: ["fp32", "fp16", "bf16", "int8", "int4"], default: "bf16" }),
            field("training.optimizer", "enum", "Optimizer passed to gpu-mem-calculator.", "传递给 gpu-mem-calculator 的优化器。", { options: ["adamw", "adamw_8bit", "sgd"], default: "adamw" }),
            field("training.micro_batch_size", "int", "Per-GPU micro batch size.", "每张 GPU 的 micro batch size。", { required: true }),
            field("training.gradient_accumulation_steps", "int", "Number of gradient accumulation steps.", "梯度累积步数。", { required: true }),
            field("training.global_batch_size", "int", "Global batch size used by llm-analysis.", "llm-analysis 使用的全局 batch size。", { required: true }),
            field("training.epochs", "int", "Informational in the current MVP; token count drives time estimate.", "当前 MVP 中主要是信息字段；时长估算由 total_tokens_b 驱动。", { default: 1 }),
            field("training.total_tokens_b", "float", "Total training tokens in billions.", "训练 token 总量，单位为十亿。", { required: true }),
            field("training.activation_checkpointing", "int", "Activation recomputation level from 0 to 4.", "激活重计算等级，取值范围 0 到 4。", { default: 0, min: 0, max: 4 }),
          ],
        },
        {
          id: "peft",
          title: "peft",
          description: { en: "Schema-only PEFT metadata", zh: "仅用于 schema 的 PEFT 元数据" },
          fields: [
            field("peft.enabled", "bool", "Enable the PEFT schema path. Must be false for full fine-tuning.", "启用 PEFT schema 路径。full fine-tuning 时必须为 false。", { default: false }),
            field("peft.method", "enum", "Must match training.mode when mode is lora or qlora.", "当 training.mode 为 lora 或 qlora 时必须一致。", { options: ["lora", "qlora"], nullable: true }),
            field("peft.trainable_params_b", "float", "Trainable parameter count in billions. Required for PEFT modes.", "可训练参数量，单位十亿。PEFT 模式必填。", { nullable: true }),
            field("peft.lora_rank", "int", "LoRA rank metadata.", "LoRA rank 元数据。", { nullable: true }),
            field("peft.lora_alpha", "int", "LoRA alpha metadata.", "LoRA alpha 元数据。", { nullable: true }),
            field("peft.target_modules", "string_list", "Comma-separated target module names for LoRA metadata.", "LoRA 目标模块名称，用逗号分隔。", { nullable: true, full: true }),
          ],
        },
        {
          id: "parallelism",
          title: "parallelism",
          description: { en: "Distributed layout", zh: "分布式并行布局" },
          fields: [
            field("parallelism.num_gpus", "int", "Total GPU count used by the run.", "本次运行使用的 GPU 总数。", { required: true }),
            field("parallelism.tensor_parallel_size", "int", "Tensor parallel degree.", "张量并行大小。", { default: 1 }),
            field("parallelism.pipeline_parallel_size", "int", "Pipeline parallel degree.", "流水线并行大小。", { default: 1 }),
            field("parallelism.data_parallel_size", "int", "Data parallel degree.", "数据并行大小。", { default: 1 }),
            field("parallelism.expert_parallel_size", "int", "Expert parallel degree passed to llm-analysis. Must be 1 for dense.", "传递给 llm-analysis 的专家并行大小。dense 必须为 1。", { default: 1 }),
            field("parallelism.sequence_parallel", "bool", "Enable sequence parallel mapping in llm-analysis.", "启用 llm-analysis 中的 sequence parallel 映射。", { default: false }),
          ],
        },
        {
          id: "deepspeed",
          title: "deepspeed",
          description: { en: "ZeRO and offload", zh: "ZeRO 与 offload 配置" },
          fields: [
            field("deepspeed.enabled", "bool", "Select the DeepSpeed engine in gpu-mem-calculator.", "在 gpu-mem-calculator 中选择 DeepSpeed 引擎。", { default: true }),
            field("deepspeed.zero_stage", "int", "ZeRO stage passed to both backends when enabled.", "启用时传递给两个后端的 ZeRO stage。", { default: 3, min: 0, max: 3 }),
            field("deepspeed.offload_optimizer", "enum", "Optimizer state offload setting.", "优化器状态 offload 配置。", { options: ["none", "cpu", "nvme"], default: "none" }),
            field("deepspeed.offload_param", "enum", "Parameter offload setting.", "参数 offload 配置。", { options: ["none", "cpu", "nvme"], default: "none" }),
          ],
        },
        {
          id: "hardware",
          title: "hardware",
          description: { en: "Hardware profile and efficiency", zh: "硬件 profile 与效率假设" },
          fields: [
            field("hardware.profile", "string", "Hardware profile name. Also used as fallback for llm-analysis GPU lookup.", "硬件 profile 名称。也会作为 llm-analysis GPU 查找的兜底值。", { required: true }),
            field("hardware.gpu_type", "string", "Human-readable GPU type, such as H100-80G or A100-80G.", "人类可读的 GPU 类型，例如 H100-80G 或 A100-80G。", { required: true }),
            field("hardware.gpu_count", "int", "Total GPU count. Must equal parallelism.num_gpus.", "GPU 总数，必须等于 parallelism.num_gpus。", { required: true }),
            field("hardware.gpu_memory_gb", "float", "Memory per GPU in GB.", "单卡显存，单位 GB。", { required: true }),
            field("hardware.flops_efficiency", "float", "Achieved FLOPS efficiency passed to llm-analysis.", "传递给 llm-analysis 的 FLOPS 效率。", { default: 1.0, min: 0 }),
            field("hardware.memory_efficiency", "float", "HBM memory efficiency passed to llm-analysis.", "传递给 llm-analysis 的 HBM 显存效率。", { default: 1.0, min: 0 }),
          ],
        },
        {
          id: "cost",
          title: "cost",
          description: { en: "Cost profile selection", zh: "成本 profile 选择" },
          fields: [
            field("cost.price_profile", "string", "Price profile key used for rental cost lookup.", "用于租赁成本查询的 price profile 键。", { required: true }),
          ],
        },
        {
          id: "price",
          title: "price",
          description: { en: "Editable price book override for the current profile", zh: "当前 profile 可编辑的价格覆盖项" },
          fields: [
            field("price.profile_name", "string", "Price profile name to override in the request-local price book.", "在当前请求价格表中要覆盖的 price profile 名称。", { required: true }),
            field("price.currency", "string", "Currency label used in cost display.", "成本展示使用的货币标签。", { default: "CNY" }),
            field("price.hours_per_month", "float", "Hours per month used to convert monthly rental cost to hourly cost.", "把月租成本换算为小时成本时使用的每月小时数。", { default: 720 }),
            field("price.gpu_type", "string", "GPU type stored in the request-local price book.", "写入当前请求价格表的 GPU 类型。", { required: true }),
            field("price.gpu_count", "int", "GPU count stored in the request-local price book.", "写入当前请求价格表的 GPU 数量。", { required: true }),
            field("price.monthly_rental_cost", "float", "Monthly rental cost for this price profile.", "这个 price profile 的月租成本。", { required: true, min: 0 }),
          ],
        },
        {
          id: "ui",
          title: "ui",
          description: { en: "Summary settings", zh: "总结分析设置" },
          fields: [
            field("ui.summarize", "bool", "Call OpenAI or DeepSeek for a short Markdown summary after the estimator returns.", "在估算结果返回后，调用 OpenAI 或 DeepSeek 生成 Markdown 简短总结。", { default: true }),
            field("ui.provider", "enum", "Summary LLM provider. Auto follows local config and available keys.", "总结分析的 LLM 提供方。Auto 会跟随本地配置和可用 key。", { options: ["auto", "openai", "deepseek"], default: "auto" }),
          ],
        },
      ];

      const example = {
        version: "0.1",
        run: {
          name: "qwen_7b_full_h100_zero3",
          description: "qwen-like dense full fine-tuning on H100 x8",
