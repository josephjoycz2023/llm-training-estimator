      function ui() {
        return text[language];
      }

      function allFields() {
        return schema.flatMap((section) => section.fields);
      }

      function getPath(obj, path) {
        return path.split(".").reduce((value, key) => (value == null ? undefined : value[key]), obj);
      }

      function setPath(obj, path, value) {
        const parts = path.split(".");
        let cursor = obj;
        while (parts.length > 1) {
          const part = parts.shift();
          cursor[part] ??= {};
          cursor = cursor[part];
        }
        cursor[parts[0]] = value;
      }

      function findField(path) {
        return allFields().find((item) => item.path === path);
      }

      function findInput(path) {
        return document.querySelector(`.field[data-path="${CSS.escape(path)}"] [data-input]`);
      }

      function formatNumber(value, digits = 2) {
        if (value == null || !Number.isFinite(Number(value))) return "n/a";
        return Number(value).toFixed(digits);
      }

      function escapeHtml(value) {
        return String(value).replace(/[&<>"']/g, (char) => ({
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          '"': "&quot;",
          "'": "&#39;",
        }[char]));
      }

      function renderMarkdown(markdown) {
        const lines = markdown.split(/\r?\n/);
        let html = "";
        let inList = false;
        for (const line of lines) {
          const trimmed = line.trim();
          if (!trimmed) {
            if (inList) {
              html += "</ul>";
              inList = false;
            }
            continue;
          }
          if (trimmed.startsWith("### ")) {
            if (inList) html += "</ul>";
            inList = false;
            html += `<h3>${inlineMarkdown(trimmed.slice(4))}</h3>`;
            continue;
          }
          if (trimmed.startsWith("## ")) {
            if (inList) html += "</ul>";
            inList = false;
            html += `<h2>${inlineMarkdown(trimmed.slice(3))}</h2>`;
            continue;
          }
          if (trimmed.startsWith("# ")) {
            if (inList) html += "</ul>";
            inList = false;
            html += `<h1>${inlineMarkdown(trimmed.slice(2))}</h1>`;
            continue;
          }
          if (/^[-*]\s+/.test(trimmed)) {
            if (!inList) {
              html += "<ul>";
              inList = true;
            }
            html += `<li>${inlineMarkdown(trimmed.replace(/^[-*]\s+/, ""))}</li>`;
            continue;
          }
          if (inList) {
            html += "</ul>";
            inList = false;
          }
          html += `<p>${inlineMarkdown(trimmed)}</p>`;
        }
        if (inList) html += "</ul>";
        return html;
      }

      function inlineMarkdown(textValue) {
        return escapeHtml(textValue)
          .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
          .replace(/`([^`]+)`/g, "<code>$1</code>");
      }

      function metric(label, value, className = "") {
        return `<div class="metric"><span>${escapeHtml(label)}</span><strong class="${className}">${escapeHtml(value ?? "n/a")}</strong></div>`;
      }

      function setInputValue(path, value) {
        const input = findInput(path);
        if (!input) return;
        const spec = findField(path);
        if (spec?.type === "bool") {
          input.checked = Boolean(value);
        } else if (value == null) {
          input.value = "";
        } else if (Array.isArray(value)) {
          input.value = value.join(", ");
        } else {
          input.value = String(value);
        }
        validateField(input.closest(".field"));
      }

      function readFieldValue(path) {
        const input = findInput(path);
        const spec = findField(path);
        if (!input || !spec) return undefined;
        return parseField(spec, input);
      }

      function populateHardwareSelectors() {
        const presetSelect = document.getElementById("hardwarePreset");
        const compareOptions = document.getElementById("compareOptions");
        if (!presetSelect || !compareOptions) return;

        if (!hardwareOptions.length) {
          presetSelect.innerHTML = `<option value="">${escapeHtml(ui().comparison.loading)}</option>`;
          compareOptions.innerHTML = `<div class="helper">${escapeHtml(ui().comparison.noOptions)}</div>`;
          return;
        }

        const currentProfile = String(readFieldValue("hardware.profile") || "");
        const selectedProfiles = new Set(getSelectedCompareProfiles());
        if (!selectedProfiles.size && currentProfile) selectedProfiles.add(currentProfile);
        presetSelect.innerHTML = [
          `<option value="">${escapeHtml(ui().comparison.presetEmpty)}</option>`,
          ...hardwareOptions.map((option) => {
            const label = `${option.gpu_type} x${option.gpu_count} (${option.profile})`;
            const selected = option.profile === currentProfile ? " selected" : "";
            return `<option value="${escapeHtml(option.profile)}"${selected}>${escapeHtml(label)}</option>`;
          }),
        ].join("");

        compareOptions.innerHTML = hardwareOptions
          .map((option) => {
            const checked = selectedProfiles.has(option.profile) ? " checked" : "";
            const label = `${option.gpu_type} x${option.gpu_count}`;
            return `
              <label class="compare-chip">
                <input type="checkbox" value="${escapeHtml(option.profile)}"${checked} />
                <span>${escapeHtml(label)}</span>
              </label>
            `;
          })
          .join("");
      }

      function renderHardwareControls(fieldsContainer) {
        const block = document.createElement("div");
        block.className = "preset-stack";
        block.innerHTML = `
          <div class="field full special-field">
            <div class="meaning" id="hardwarePresetMeaning">${ui().comparison.presetMeaning}</div>
            <div class="label-row">
              <label for="hardwarePreset">${ui().comparison.presetLabel}</label>
              <span class="type" id="hardwarePresetType">${ui().comparison.presetType}</span>
            </div>
            <select id="hardwarePreset"></select>
          </div>
          <div class="field full special-field">
            <div class="meaning" id="compareMeaning">${ui().comparison.compareMeaning}</div>
            <div class="label-row">
              <label>${ui().comparison.compareLabel}</label>
              <span class="type" id="compareType">${ui().comparison.compareType}</span>
            </div>
            <div id="compareOptions" class="compare-options">
              <div class="helper">${escapeHtml(ui().comparison.loading)}</div>
            </div>
          </div>
        `;
        fieldsContainer.prepend(block);

        block.querySelector("#hardwarePreset").addEventListener("change", (event) => {
          const profile = event.target.value;
          if (!profile) return;
          applyHardwarePreset(profile);
        });
      }

      function makeField(spec) {
        const wrapper = document.createElement("div");
        wrapper.className = `field${spec.full || spec.multiline ? " full" : ""}`;
        wrapper.dataset.path = spec.path;

        wrapper.innerHTML = `
          <div class="meaning" data-meaning>${escapeHtml(spec.meaning[language])}</div>
          <div class="label-row">
            <label for="${escapeHtml(spec.path)}">${escapeHtml(spec.path)}</label>
            <span class="type">${escapeHtml(spec.type)}${spec.required ? ` · ${escapeHtml(ui().fieldMetaRequired)}` : ""}</span>
          </div>
        `;

        let input;
        if (spec.type === "enum") {
          input = document.createElement("select");
          input.innerHTML = `<option value=""></option>${(spec.options || []).map((option) => `<option value="${escapeHtml(option)}">${escapeHtml(option)}</option>`).join("")}`;
        } else if (spec.type === "bool") {
          input = document.createElement("label");
          input.className = "checkbox";
          input.innerHTML = `<input id="${escapeHtml(spec.path)}" data-input type="checkbox" /> <span>${escapeHtml(ui().checkboxEnabled)}</span>`;
          wrapper.appendChild(input);
          wrapper.insertAdjacentHTML("beforeend", `<div class="error"></div>`);
          input.querySelector("input").addEventListener("input", () => validateField(wrapper));
          return wrapper;
        } else if (spec.multiline) {
          input = document.createElement("textarea");
        } else {
          input = document.createElement("input");
          input.type = spec.type === "int" || spec.type === "float" ? "number" : "text";
          if (spec.type === "int") input.step = "1";
          if (spec.type === "float") input.step = "any";
          if (spec.min !== undefined) input.min = String(spec.min);
          if (spec.max !== undefined) input.max = String(spec.max);
        }

        input.id = spec.path;
        input.dataset.input = "true";
        if (spec.default !== undefined && spec.type !== "bool") {
          input.value = String(spec.default);
        }
        input.addEventListener("input", () => {
          validateField(wrapper);
          if (spec.path === "hardware.profile") populateHardwareSelectors();
        });
        wrapper.appendChild(input);
        wrapper.insertAdjacentHTML("beforeend", `<div class="error"></div>`);
        return wrapper;
      }

      function renderForm() {
        const form = document.getElementById("configForm");
        form.innerHTML = "";

        for (const [index, section] of schema.entries()) {
          const details = document.createElement("details");
          details.className = "section";
          details.open = index < 3;
          details.dataset.sectionId = section.id;
          details.innerHTML = `
            <summary>
              <strong>${escapeHtml(section.title)}</strong>
              <span data-section-description>${escapeHtml(section.description[language])}</span>
            </summary>
          `;

          const fieldsContainer = document.createElement("div");
          fieldsContainer.className = "fields";
          if (section.id === "hardware") {
            renderHardwareControls(fieldsContainer);
          }
          for (const spec of section.fields) {
            fieldsContainer.appendChild(makeField(spec));
          }
          details.appendChild(fieldsContainer);
          form.appendChild(details);
        }

        applyDefaultValues();
      }

      function applyDefaultValues() {
        for (const spec of allFields()) {
          if (spec.default !== undefined) {
            setInputValue(spec.path, spec.default);
          }
        }
        setProgressStep("waiting", "waiting", "waiting", "waiting", "waiting");
      }

      function updateStaticTexts() {
        document.documentElement.lang = language === "zh" ? "zh-CN" : "en";
        document.getElementById("appTitle").textContent = ui().appTitle;
        document.getElementById("appDescription").textContent = ui().appDescription;
        document.getElementById("languageToggle").textContent = ui().languageToggle;
        document.getElementById("loadExample").textContent = ui().loadExample;
        document.getElementById("clearForm").textContent = ui().clearForm;
        document.getElementById("estimateButton").textContent = ui().estimateButton;
        document.getElementById("progressTitle").textContent = ui().progressTitle;
        document.getElementById("resultTitle").textContent = ui().resultTitle;
        document.getElementById("comparisonTitle").textContent = ui().comparisonTitle;
        document.getElementById("comparisonHelper").textContent = ui().comparisonHelper;
        document.getElementById("summaryTitle").textContent = ui().summaryTitle;
        document.getElementById("rawResultTitle").textContent = ui().rawResultTitle;
      }

      function updateFieldCopy() {
        document.querySelectorAll("[data-section-description]").forEach((element, index) => {
          element.textContent = schema[index].description[language];
        });

        for (const spec of allFields()) {
          const wrapper = document.querySelector(`.field[data-path="${CSS.escape(spec.path)}"]`);
          if (!wrapper) continue;
          wrapper.querySelector("[data-meaning]").textContent = spec.meaning[language];
          wrapper.querySelector(".type").textContent = `${spec.type}${spec.required ? ` · ${ui().fieldMetaRequired}` : ""}`;
          const checkboxText = wrapper.querySelector(".checkbox span");
          if (checkboxText) checkboxText.textContent = ui().checkboxEnabled;
        }

        const hardwarePresetMeaning = document.getElementById("hardwarePresetMeaning");
        const hardwarePresetType = document.getElementById("hardwarePresetType");
        const compareMeaning = document.getElementById("compareMeaning");
        const compareType = document.getElementById("compareType");
        if (hardwarePresetMeaning) hardwarePresetMeaning.textContent = ui().comparison.presetMeaning;
        if (hardwarePresetType) hardwarePresetType.textContent = ui().comparison.presetType;
        if (compareMeaning) compareMeaning.textContent = ui().comparison.compareMeaning;
        if (compareType) compareType.textContent = ui().comparison.compareType;
        populateHardwareSelectors();
      }

      function loadValues(values) {
        for (const spec of allFields()) {
          const value = getPath(values, spec.path);
          if (value !== undefined) {
            setInputValue(spec.path, value);
          } else {
            setInputValue(spec.path, spec.default ?? (spec.type === "bool" ? false : ""));
          }
        }
        populateHardwareSelectors();
      }

      function clearValues() {
        for (const wrapper of document.querySelectorAll(".field[data-path]")) {
          const spec = findField(wrapper.dataset.path);
          if (!spec) continue;
          const input = wrapper.querySelector("[data-input]");
          if (!input) continue;
          if (spec.type === "bool") input.checked = Boolean(spec.default);
          else if (spec.default !== undefined) input.value = String(spec.default);
          else input.value = "";
          validateField(wrapper);
        }
        latestCompareData = null;
        populateHardwareSelectors();
      }

      function parseField(spec, input) {
        if (spec.type === "bool") return input.checked;
        const raw = String(input.value || "").trim();
        if (raw === "") {
          if (spec.nullable) return null;
          return undefined;
        }
        if (spec.type === "int") {
          const value = Number(raw);
          if (!Number.isInteger(value)) throw new Error(ui().errors.integer);
          return value;
        }
        if (spec.type === "float") {
          const value = Number(raw);
          if (!Number.isFinite(value)) throw new Error(ui().errors.number);
          return value;
        }
        if (spec.type === "string_list") {
          return raw.split(",").map((item) => item.trim()).filter(Boolean);
        }
        return raw;
      }

      function validateField(wrapper, forSubmit = false) {
        const spec = findField(wrapper.dataset.path);
        const input = wrapper.querySelector("[data-input]");
        const error = wrapper.querySelector(".error");
        wrapper.classList.remove("invalid");
        error.textContent = "";
        try {
          const value = parseField(spec, input);
          if (forSubmit && spec.required && (value === undefined || value === null || value === "")) {
            throw new Error(ui().errors.required);
          }
          if ((spec.type === "int" || spec.type === "float") && value !== undefined && value !== null) {
            if (spec.min !== undefined && value < spec.min) throw new Error(ui().errors.min(spec.min));
            if (spec.max !== undefined && value > spec.max) throw new Error(ui().errors.max(spec.max));
          }
          return true;
        } catch (errorValue) {
          wrapper.classList.add("invalid");
          error.textContent = errorValue.message;
          return false;
        }
      }

      function getSelectedCompareProfiles() {
        return Array.from(document.querySelectorAll("#compareOptions input[type='checkbox']:checked")).map((input) => input.value);
      }

      function buildPricesPayload(price, baseProfile) {
        const hardwarePrices = {};
        for (const option of hardwareOptions) {
          hardwarePrices[option.profile] = {
            gpu_type: option.gpu_type,
            gpu_count: option.gpu_count,
            monthly_rental_cost: option.monthly_rental_cost,
          };
        }

        const profileName = price.profile_name || baseProfile || "custom";
        hardwarePrices[profileName] = {
          gpu_type: price.gpu_type,
          gpu_count: price.gpu_count,
          monthly_rental_cost: price.monthly_rental_cost,
        };

        return {
          currency: price.currency || "CNY",
          hours_per_month: price.hours_per_month || 720,
          hardware_prices: hardwarePrices,
        };
      }

      function collectPayload() {
        let valid = true;
        const data = {};

        for (const spec of allFields()) {
          const wrapper = document.querySelector(`.field[data-path="${CSS.escape(spec.path)}"]`);
          valid = validateField(wrapper, true) && valid;
          if (!valid && wrapper.classList.contains("invalid")) continue;
          const value = parseField(spec, wrapper.querySelector("[data-input]"));
          if (value !== undefined) setPath(data, spec.path, value);
        }

        if (!valid) throw new Error(ui().errors.fixFields);

        const config = structuredClone(data);
        const price = config.price || {};
        const uiConfig = config.ui || {};
        delete config.price;
        delete config.ui;

        if (!config.cost?.price_profile && price.profile_name) {
          config.cost ??= {};
          config.cost.price_profile = price.profile_name;
        }

        const baseProfile = config.cost?.price_profile || config.hardware?.profile || price.profile_name || "custom";
        const compareProfiles = Array.from(new Set([baseProfile, ...getSelectedCompareProfiles()])).filter(Boolean);

        return {
          config,
          prices: buildPricesPayload(price, baseProfile),
          summarize: Boolean(uiConfig.summarize),
          provider: uiConfig.provider || "auto",
          language,
          compareProfiles,
        };
      }

      function showStatus(message, hidden = false) {
        const status = document.getElementById("status");
        status.hidden = hidden;
        status.textContent = message;
      }

      function setProgressStep(validation, estimate, compare, summary, display) {
        progressState.steps = [validation, estimate, compare, summary, display];
        const labels = ui().progressLabels;
        document.getElementById("progressSteps").innerHTML = [
          metric(labels[0], ui().progressStates[validation] || validation),
          metric(labels[1], ui().progressStates[estimate] || estimate),
          metric(labels[2], ui().progressStates[compare] || compare),
          metric(labels[3], ui().progressStates[summary] || summary),
          metric(labels[4], ui().progressStates[display] || display),
        ].join("");
      }

      function resolveEtaText() {
        if (progressState.etaMode === "left") return ui().eta.left(progressState.etaValue);
        if (progressState.etaMode === "compare") return ui().eta.compare;
        if (progressState.etaMode === "summary") return ui().eta.summary;
        if (progressState.etaMode === "ready") return ui().eta.ready;
        return ui().eta.unknown;
      }

      function setProgress(percent, stageKey, etaMode = "unknown", etaValue = 0) {
        currentProgressPercent = percent;
        progressState.stageKey = stageKey;
        progressState.etaMode = etaMode;
        progressState.etaValue = etaValue;
        document.getElementById("progressFill").style.width = `${percent}%`;
        document.getElementById("progressStage").textContent = ui().progressStages[stageKey] || stageKey;
        document.getElementById("progressEta").textContent = resolveEtaText();
      }

      function startProgressAnimation(targetPercent, stageKey, totalSeconds, etaMode = "left") {
        clearInterval(progressTimer);
        const startPercent = currentProgressPercent;
        const startedAt = Date.now();
        progressTimer = setInterval(() => {
          const elapsed = (Date.now() - startedAt) / 1000;
          const ratio = Math.min(elapsed / totalSeconds, 1);
          const nextPercent = startPercent + (targetPercent - startPercent) * ratio;
          const remaining = Math.max(totalSeconds - elapsed, 0);
          setProgress(nextPercent, stageKey, etaMode, Math.ceil(remaining));
          if (ratio >= 1) clearInterval(progressTimer);
        }, 150);
      }

      function stopProgressAnimation() {
        clearInterval(progressTimer);
        progressTimer = null;
      }

      function formatMetricValue(key, data) {
        const result = data.result;
        const memory = result.memory || {};
        const time = result.time || {};
        const cost = result.cost || {};
        if (key === "runnable") return result.runnable ? ui().values.yes : ui().values.no;
        if (key === "risk") return result.risk_level || "n/a";
        if (key === "memory") {
          if (memory.memory_per_gpu_gb == null || memory.gpu_memory_limit_gb == null) return "n/a";
          return `${formatNumber(memory.memory_per_gpu_gb)} / ${formatNumber(memory.gpu_memory_limit_gb, 0)} GB`;
        }
        if (key === "utilization") {
          if (memory.memory_utilization == null) return "n/a";
          return `${formatNumber(memory.memory_utilization * 100, 1)}%`;
        }
        if (key === "time") return time.total_time_hours == null ? "n/a" : `${formatNumber(time.total_time_hours)} h`;
        if (key === "gpuHours") return time.gpu_hours == null ? "n/a" : formatNumber(time.gpu_hours);
        if (key === "cost") return cost.estimated_cost == null ? "n/a" : `${formatNumber(cost.estimated_cost)} ${cost.currency}`;
        if (key === "provider") return data.summary_provider || ui().values.pending;
        return "";
      }

      function renderResult(data) {
        latestResult = data;
        const result = data.result;
        const memory = result.memory || {};
        const gpuCount = result?.time?.raw_output?.total_num_gpus || result?.memory?.raw_output?.num_gpus || result?.memory?.raw_output?.total_num_gpus || result?.memory?.raw_output?.gpu_config?.num_gpus || result?.memory?.raw_output?.input?.gpu_config?.num_gpus || result?.memory?.raw_output?.cluster_gpus || result?.memory?.raw_output?.world_size || result?.memory?.raw_output?.gpu_count || result?.memory?.raw_output?.n_gpus || result?.memory?.raw_output?.parallelism_config?.total_gpus || readFieldValue("hardware.gpu_count");

        const runnableClass = result.runnable ? "status-ok" : "status-danger";
        const riskClass = result.risk_level === "low"
          ? "status-ok"
          : result.risk_level === "medium"
            ? "status-warn"
            : "status-danger";

        document.getElementById("metrics").innerHTML = [
          metric(ui().metrics.runnable, formatMetricValue("runnable", data), runnableClass),
          metric(ui().metrics.risk, formatMetricValue("risk", data), riskClass),
          metric(ui().metrics.memory, formatMetricValue("memory", data)),
          metric(ui().metrics.utilization, formatMetricValue("utilization", data)),
          metric(ui().metrics.time, formatMetricValue("time", data)),
          metric(ui().metrics.gpuHours, formatMetricValue("gpuHours", data)),
          metric(ui().metrics.cost, formatMetricValue("cost", data)),
          metric(ui().metrics.provider, formatMetricValue("provider", data)),
        ].join("");

        document.getElementById("memoryNote").textContent =
          gpuCount && memory.memory_per_gpu_gb != null
            ? ui().memoryNote.withCount(gpuCount)
            : ui().memoryNote.generic;

        document.getElementById("rawResult").textContent = JSON.stringify(result, null, 2);
      }

      function renderSummary(data) {
        if (data.summary_markdown) {
          document.getElementById("summary").innerHTML = renderMarkdown(data.summary_markdown);
        } else if (data.summary_error) {
          document.getElementById("summary").innerHTML =
            `<p><strong>${escapeHtml(ui().summary.unavailableTitle)}</strong></p><p>${escapeHtml(data.summary_error)}</p>`;
        } else {
          document.getElementById("summary").textContent = ui().values.noSummaryRequested;
        }
      }

      function formatDelta(value, unit, baseValue) {
        if (value == null || baseValue == null || !Number.isFinite(value) || !Number.isFinite(baseValue)) return "n/a";
        if (Math.abs(value - baseValue) < 0.005) return `0.00 ${unit}`;
        const delta = value - baseValue;
        return `${delta > 0 ? "+" : ""}${formatNumber(delta)} ${unit}`;
      }

      function renderComparison(compareData) {
        latestCompareData = compareData;
        const container = document.getElementById("comparison");
        const insights = document.getElementById("comparisonInsights");
        const baseProfile = latestResult?.result?.cost?.price_profile || readFieldValue("cost.price_profile");
        const baseTime = latestResult?.result?.time?.total_time_hours ?? null;
        const baseCost = latestResult?.result?.cost?.estimated_cost ?? null;

        if (!compareData?.items?.length) {
          container.innerHTML = `<div class="helper">${escapeHtml(ui().comparison.placeholder)}</div>`;
          insights.textContent = "";
          return;
        }

        const columns = ui().comparison.columns;
        const rows = compareData.items.map((item) => {
          if (item.error || !item.result) {
            return `
              <tr>
                <td>${escapeHtml(item.profile || "unknown")}</td>
                <td>${escapeHtml(item.gpu_type || ui().values.unavailable)}</td>
                <td>${escapeHtml(String(item.gpu_count ?? "n/a"))}</td>
                <td>n/a</td>
                <td>n/a</td>
                <td>n/a</td>
                <td>n/a</td>
                <td>n/a</td>
                <td>${escapeHtml(ui().values.no)}</td>
                <td>${escapeHtml(ui().values.unavailable)}</td>
                <td>${escapeHtml(item.error)}</td>
              </tr>
            `;
          }

          const result = item.result;
          const memory = result.memory || {};
          const time = result.time || {};
          const cost = result.cost || {};
          const currentBadge = item.profile === baseProfile ? ` <span class="badge">${escapeHtml(ui().comparison.currentBadge)}</span>` : "";

          return `
            <tr>
              <td>${escapeHtml(item.profile)}${currentBadge}</td>
              <td>${escapeHtml(item.gpu_type)}</td>
              <td>${escapeHtml(String(item.gpu_count))}</td>
              <td>${escapeHtml(memory.memory_per_gpu_gb == null || memory.gpu_memory_limit_gb == null ? "n/a" : `${formatNumber(memory.memory_per_gpu_gb)} / ${formatNumber(memory.gpu_memory_limit_gb, 0)} GB`)}</td>
              <td>${escapeHtml(time.total_time_hours == null ? "n/a" : `${formatNumber(time.total_time_hours)} h`)}</td>
              <td>${escapeHtml(cost.estimated_cost == null ? "n/a" : `${formatNumber(cost.estimated_cost)} ${cost.currency}`)}</td>
              <td>${escapeHtml(formatDelta(time.total_time_hours, "h", baseTime))}</td>
              <td>${escapeHtml(cost.estimated_cost == null || baseCost == null ? "n/a" : `${formatDelta(cost.estimated_cost, cost.currency || "", baseCost)}`)}</td>
              <td>${escapeHtml(result.runnable ? ui().values.yes : ui().values.no)}</td>
              <td>${escapeHtml(result.risk_level || "n/a")}</td>
              <td>${escapeHtml(result.warnings?.[0] || ui().values.none)}</td>
            </tr>
          `;
        }).join("");

        container.innerHTML = `
          <div class="comparison-table-shell">
            <table class="comparison-table">
              <thead>
                <tr>
                  <th>${escapeHtml(columns.profile)}</th>
                  <th>${escapeHtml(columns.gpu)}</th>
                  <th>${escapeHtml(columns.count)}</th>
                  <th>${escapeHtml(columns.memory)}</th>
                  <th>${escapeHtml(columns.time)}</th>
                  <th>${escapeHtml(columns.cost)}</th>
                  <th>${escapeHtml(columns.deltaTime)}</th>
                  <th>${escapeHtml(columns.deltaCost)}</th>
                  <th>${escapeHtml(columns.runnable)}</th>
                  <th>${escapeHtml(columns.risk)}</th>
                  <th>${escapeHtml(columns.notes)}</th>
                </tr>
              </thead>
              <tbody>${rows}</tbody>
            </table>
          </div>
        `;

        const validItems = compareData.items.filter((item) => item.result && !item.error);
        if (validItems.length < 2) {
          insights.textContent = ui().comparison.insightOnlyOne;
          return;
        }

        const fastest = validItems
          .filter((item) => Number.isFinite(item.result.time?.total_time_hours))
          .sort((left, right) => left.result.time.total_time_hours - right.result.time.total_time_hours)[0];
        const cheapest = validItems
          .filter((item) => Number.isFinite(item.result.cost?.estimated_cost))
          .sort((left, right) => left.result.cost.estimated_cost - right.result.cost.estimated_cost)[0];

        const parts = [];
        if (fastest) {
          parts.push(ui().comparison.insightFastest(
            `${fastest.gpu_type} x${fastest.gpu_count}`,
            `${formatNumber(fastest.result.time.total_time_hours)} h`
          ));
        }
        if (cheapest) {
          parts.push(ui().comparison.insightCheapest(
            `${cheapest.gpu_type} x${cheapest.gpu_count}`,
            `${formatNumber(cheapest.result.cost.estimated_cost)} ${cheapest.result.cost.currency}`
          ));
        }
        insights.textContent = parts.join(" ");
      }

      function applyHardwarePreset(profile) {
        const option = hardwareOptions.find((item) => item.profile === profile);
        if (!option) return;

        setInputValue("hardware.profile", option.profile);
        setInputValue("hardware.gpu_type", option.gpu_type);
        setInputValue("hardware.gpu_count", option.gpu_count);
        setInputValue("hardware.gpu_memory_gb", option.gpu_memory_gb);
        setInputValue("cost.price_profile", option.profile);
        setInputValue("price.profile_name", option.profile);
        setInputValue("price.gpu_type", option.gpu_type);
        setInputValue("price.gpu_count", option.gpu_count);
        setInputValue("price.monthly_rental_cost", option.monthly_rental_cost);

        const tp = Number(readFieldValue("parallelism.tensor_parallel_size") || 1);
        const pp = Number(readFieldValue("parallelism.pipeline_parallel_size") || 1);
        const perReplica = tp * pp;
        if (option.gpu_count % perReplica === 0) {
          setInputValue("parallelism.num_gpus", option.gpu_count);
          setInputValue("parallelism.data_parallel_size", option.gpu_count / perReplica);
          showStatus("", true);
        } else {
          showStatus(ui().hardwarePresetWarning);
        }

        populateHardwareSelectors();
      }

      async function fetchJson(url, payload) {
        const response = await fetch(url, {
          method: payload ? "POST" : "GET",
          headers: payload ? { "Content-Type": "application/json" } : undefined,
          body: payload ? JSON.stringify(payload) : undefined,
        });
        const data = await response.json();
        if (!response.ok) {
          throw new Error(typeof data.detail === "string" ? data.detail : JSON.stringify(data.detail));
        }
        return data;
      }

      async function loadHardwareOptions() {
        showStatus(ui().status.loadingHardware);
        try {
          const data = await fetchJson(`${API_BASE}/api/hardware-options`);
          hardwareOptions = data.items || [];
          populateHardwareSelectors();
          showStatus("", true);
        } catch (errorValue) {
          hardwareOptions = [];
          populateHardwareSelectors();
          showStatus(errorValue.message || String(errorValue));
        }
      }

      async function runCompare(payload) {
        if (!payload.compareProfiles.length) {
          renderComparison({ items: [] });
          return { ok: true, skipped: true };
        }

        document.getElementById("comparison").innerHTML = `<div class="helper">${escapeHtml(ui().comparison.waiting)}</div>`;
        setProgressStep("done", "done", "running", payload.summarize ? "queued" : "skipped", "done");
        if (!payload.summarize) {
          setProgress(84, "comparing", "compare");
          startProgressAnimation(96, "comparing", 4, "left");
        }

        try {
          const compareData = await fetchJson(`${API_BASE}/api/compare`, {
            config: payload.config,
            prices: payload.prices,
            compare_profiles: payload.compareProfiles,
          });
          renderComparison(compareData);
          setProgressStep(
            "done",
            "done",
            "done",
            payload.summarize ? progressState.steps[3] : "skipped",
            "done"
          );
          return { ok: true, skipped: false };
        } catch (errorValue) {
          renderComparison({
            items: [
              {
                profile: "compare",
                gpu_type: ui().values.unavailable,
                gpu_count: "n/a",
                error: errorValue.message || String(errorValue),
                result: null,
              },
            ],
          });
          setProgressStep(
            "done",
            "done",
            "unavailable",
            payload.summarize ? progressState.steps[3] : "skipped",
            "done"
          );
          return { ok: false, skipped: false, error: errorValue };
        } finally {
          if (!payload.summarize) stopProgressAnimation();
        }
      }

      async function runSummary(payload, result) {
        const compareProfiles = Array.isArray(payload.compareProfiles) ? payload.compareProfiles : [];
        setProgressStep(
          "done",
          "done",
          compareProfiles.length ? progressState.steps[2] : "skipped",
          "running",
          "done"
        );
        setProgress(84, "summarizing", "summary");
        startProgressAnimation(96, "summarizing", payload.provider === "deepseek" ? 18 : 10, "left");

        try {
          const data = await fetchJson(`${API_BASE}/api/summary`, { ...payload, result });
          renderSummary(data);
          if (latestResult) {
            latestResult.summary_provider = data.summary_provider;
            renderResult(latestResult);
          }
          setProgressStep(
            "done",
            "done",
            compareProfiles.length ? progressState.steps[2] : "skipped",
            "done",
            "done"
          );
          return { ok: true };
        } catch (errorValue) {
          renderSummary({ summary_markdown: "", summary_error: errorValue.message || String(errorValue) });
          setProgressStep(
            "done",
            "done",
            compareProfiles.length ? progressState.steps[2] : "skipped",
            "unavailable",
            "done"
          );
          return { ok: false, error: errorValue };
        } finally {
          stopProgressAnimation();
        }
      }

      async function estimate() {
        document.getElementById("estimateButton").disabled = true;
        document.getElementById("summary").textContent = ui().summary.waiting;
        document.getElementById("comparison").innerHTML = `<div class="helper">${escapeHtml(ui().values.comparisonLoading)}</div>`;
        document.getElementById("comparisonInsights").textContent = "";

        try {
          const payload = collectPayload();
          const estimatePayload = {
            config: payload.config,
            prices: payload.prices,
            provider: payload.provider,
            language: payload.language,
            compareProfiles: payload.compareProfiles,
          };
          latestEstimatePayload = estimatePayload;

          showStatus(ui().status.validating);
          setProgress(8, "validating", "left", 2);
          setProgressStep("running", "waiting", "waiting", "waiting", "waiting");

          startProgressAnimation(62, "estimating", 3, "left");
          const estimateData = await fetchJson(`${API_BASE}/api/estimate`, estimatePayload);
          stopProgressAnimation();

          renderResult(estimateData);
          setProgress(72, "estimateReady", payload.summarize ? "summary" : payload.compareProfiles.length ? "compare" : "ready");
          setProgressStep(
            "done",
            "done",
            payload.compareProfiles.length ? "queued" : "skipped",
            payload.summarize ? "queued" : "skipped",
            "done"
          );
          showStatus(payload.compareProfiles.length || payload.summarize ? ui().status.waitingBackground : ui().status.estimateReady);

          if (!payload.compareProfiles.length) {
            renderComparison({ items: [] });
          }
          if (!payload.summarize) {
            renderSummary({ summary_markdown: "", summary_error: null });
          }

          const backgroundTasks = [];
          if (payload.compareProfiles.length) {
            backgroundTasks.push(runCompare(payload));
          }
          if (payload.summarize) {
            backgroundTasks.push(runSummary(estimatePayload, estimateData.result));
          }

          if (!backgroundTasks.length) {
            setProgress(100, "complete", "ready");
            setProgressStep("done", "done", "skipped", "skipped", "complete");
            showStatus(ui().status.estimateComplete, true);
            document.getElementById("estimateButton").disabled = false;
            return;
          }

          const settled = await Promise.all(backgroundTasks);
          const hasFailure = settled.some((item) => item && item.ok === false);
          const compareRan = payload.compareProfiles.length > 0;
          const summaryRan = payload.summarize;

          setProgress(100, hasFailure ? "warning" : "complete", "ready");
          setProgressStep(
            "done",
            "done",
            compareRan ? progressState.steps[2] : "skipped",
            summaryRan ? progressState.steps[3] : "skipped",
            "complete"
          );

          if (hasFailure) {
            showStatus(ui().status.summaryWarning);
          } else if (compareRan && summaryRan) {
            showStatus(ui().status.allComplete, true);
          } else if (compareRan) {
            showStatus(ui().status.compareComplete, true);
          } else {
            showStatus(ui().status.summaryComplete, true);
          }
        } catch (errorValue) {
          stopProgressAnimation();
          setProgress(0, "idle", "unknown");
          setProgressStep("error", "waiting", "waiting", "waiting", "waiting");
          showStatus(errorValue.message || String(errorValue));
        } finally {
          document.getElementById("estimateButton").disabled = false;
        }
      }

      function refreshLocalizedUi() {
        updateStaticTexts();
        updateFieldCopy();
        setProgress(currentProgressPercent, progressState.stageKey, progressState.etaMode, progressState.etaValue);
        setProgressStep(...progressState.steps);
        if (latestResult) {
          renderResult(latestResult);
        } else {
          document.getElementById("metrics").innerHTML = [
            metric(ui().metrics.runnable, ui().values.notRun),
            metric(ui().metrics.risk, ui().values.notRun),
            metric(ui().metrics.memory, ui().values.notRun),
            metric(ui().metrics.utilization, ui().values.notRun),
            metric(ui().metrics.time, ui().values.notRun),
            metric(ui().metrics.gpuHours, ui().values.notRun),
            metric(ui().metrics.cost, ui().values.notRun),
            metric(ui().metrics.provider, ui().values.notRun),
          ].join("");
          document.getElementById("rawResult").textContent = "{}";
        }

        if (latestCompareData) renderComparison(latestCompareData);
        else document.getElementById("comparison").innerHTML = `<div class="helper">${escapeHtml(ui().comparison.placeholder)}</div>`;

        if (!latestResult) {
          document.getElementById("summary").textContent = ui().summary.placeholder;
        }
      }

      document.getElementById("languageToggle").addEventListener("click", () => {
        language = language === "en" ? "zh" : "en";
        refreshLocalizedUi();
        if (latestEstimatePayload && latestResult?.result) {
          const refreshedPayload = { ...latestEstimatePayload, language };
          latestEstimatePayload = refreshedPayload;
          document.getElementById("summary").textContent = ui().summary.waiting;
          runSummary(refreshedPayload, latestResult.result);
        }
      });

      document.getElementById("loadExample").addEventListener("click", () => {
        loadValues(example);
        populateHardwareSelectors();
      });

      document.getElementById("clearForm").addEventListener("click", () => {
        clearValues();
        renderComparison({ items: [] });
        renderSummary({ summary_markdown: "", summary_error: null });
        document.getElementById("summary").textContent = ui().summary.placeholder;
      });

      document.getElementById("estimateButton").addEventListener("click", estimate);

      renderForm();
      refreshLocalizedUi();
      setProgress(0, "idle", "unknown");
      setProgressStep("waiting", "waiting", "waiting", "waiting", "waiting");
      renderComparison({ items: [] });
      document.getElementById("summary").textContent = ui().summary.placeholder;
      loadValues(example);
      loadHardwareOptions().then(() => populateHardwareSelectors());
    </script>
  </body>
</html>
