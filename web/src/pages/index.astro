---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>LLM Training Estimator</title>
  </head>
  <body>
    <main class="page">
      <header class="topbar">
        <div class="brand">
          <h1 id="appTitle">LLM Training Estimator</h1>
          <p id="appDescription">
            Fill the unified schema block by block, validate typed inputs, and estimate
            memory, time, GPU-hours, and rental cost.
          </p>
        </div>
        <div class="actions">
          <button class="button" id="languageToggle" type="button">Language: English</button>
          <button class="button" id="loadExample" type="button">Load Dense Example</button>
          <button class="button" id="clearForm" type="button">Clear</button>
          <button class="button primary" id="estimateButton" type="button">Estimate</button>
        </div>
      </header>

      <div class="layout">
        <form id="configForm" novalidate></form>

        <aside class="panel">
          <div id="status" class="notice" hidden></div>

          <section class="result-card">
            <h2 id="progressTitle">Progress</h2>
            <div class="progress-shell">
              <div class="progress-bar">
                <div class="progress-fill" id="progressFill" style="width: 0%"></div>
              </div>
              <div class="progress-meta">
                <strong id="progressStage">Idle</strong>
                <span id="progressEta">Estimated time: n/a</span>
              </div>
            </div>
            <div class="summary-grid progress-grid" id="progressSteps"></div>
          </section>

          <section class="result-card">
            <h2 id="resultTitle">Result</h2>
            <div class="summary-grid" id="metrics"></div>
            <p class="helper" id="memoryNote">
              Memory is shown as average per GPU, compared against the per-GPU limit.
            </p>
          </section>

          <section class="result-card">
            <h3 id="comparisonTitle">Hardware Comparison</h3>
            <p class="helper" id="comparisonHelper">
              Select multiple GPU presets in the hardware block to compare training time and
              cost.
            </p>
            <div id="comparisonInsights" class="helper"></div>
            <div id="comparison" class="comparison-wrap"></div>
          </section>

          <section class="result-card">
            <h3 id="summaryTitle">Summary Analysis</h3>
            <div id="summary" class="markdown">Run an estimate to generate a Markdown analysis.</div>
          </section>

          <section class="result-card">
            <h3 id="rawResultTitle">Raw Result</h3>
            <pre id="rawResult" class="raw">{}</pre>
          </section>
        </aside>
      </div>
    </main>

    <script>
      const API_BASE = "http://127.0.0.1:8000";

      let language = "en";
      let progressTimer = null;
      let currentProgressPercent = 0;
      let latestResult = null;
      let latestCompareData = null;
      let latestEstimatePayload = null;
      let hardwareOptions = [];
      let progressState = {
        stageKey: "idle",
        etaMode: "unknown",
        etaValue: 0,
        steps: ["waiting", "waiting", "waiting", "waiting", "waiting"],
      };

      function field(path, type, meaningEn, meaningZh, options = {}) {
        return { path, type, meaning: { en: meaningEn, zh: meaningZh }, ...options };
      }

      const text = {
        en: {
          appTitle: "LLM Training Estimator",
          appDescription:
            "Fill the unified schema block by block, validate typed inputs, and estimate memory, time, GPU-hours, and rental cost.",
          languageToggle: "Language: English",
          loadExample: "Load Dense Example",
          clearForm: "Clear",
          estimateButton: "Estimate",
          progressTitle: "Progress",
          resultTitle: "Result",
          comparisonTitle: "Hardware Comparison",
          comparisonHelper:
            "Select multiple GPU presets in the hardware block to compare training time and cost.",
          summaryTitle: "Summary Analysis",
          rawResultTitle: "Raw Result",
          progressLabels: ["Validation", "Estimate", "Compare", "Summary", "Display"],
          progressStates: {
            idle: "Idle",
            waiting: "Waiting",
            running: "Running",
            queued: "Queued",
            done: "Done",
            skipped: "Skipped",
            unavailable: "Unavailable",
            complete: "Complete",
            error: "Error",
